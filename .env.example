# Copiar a .env y reemplazar los valores. Generar secretos con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

POSTGRES_USER=valdocco
POSTGRES_PASSWORD=CAMBIAR_password_fuerte
POSTGRES_DB=valdocco
DATABASE_URL=postgresql://valdocco:CAMBIAR_password_fuerte@localhost:5432/valdocco?schema=public

REDIS_PASSWORD=CAMBIAR_password_redis
REDIS_URL=redis://:CAMBIAR_password_redis@localhost:6379

JWT_SECRET=CAMBIAR_minimo_32_caracteres_aleatorios
JWT_REFRESH_SECRET=CAMBIAR_minimo_32_caracteres_aleatorios
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

INTERNAL_SECRET=CAMBIAR_minimo_32_caracteres_aleatorios

WEB_ORIGIN=http://localhost:3000
NODE_ENV=development
