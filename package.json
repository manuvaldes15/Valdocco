{
  "name": "valdocco",
  "version": "1.0.0",
  "private": true,
  "description": "Valdocco — Sistema de Seguimiento Académico del Complejo Educativo Católico María Auxiliadora (CECMA)",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "prisma:generate": "pnpm --filter @valdocco/prisma-client generate",
    "prisma:push": "pnpm --filter @valdocco/prisma-client push",
    "prisma:seed": "pnpm --filter @valdocco/prisma-client seed",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7.3"
  }
}
